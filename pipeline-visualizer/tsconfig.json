{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./target",
    "rootDir": ".",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "index.ts",
    "common/**/*.ts",
    "public/**/*.ts",
    "public/**/*.tsx",
    "server/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "target",
    "build",
    "**/__tests__/**"
  ]
}
